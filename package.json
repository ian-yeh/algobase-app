{
  "name": "algobase",
  "private": true,
  "workspaces": [
    "web"
  ],
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "convex": "^1.39.1",
    "jsonwebtoken": "^9.0.3"
  },
  "scripts": {
    "web": "npm run --workspace=web",
    "web:dev": "npm run dev --workspace=web",
    "web:build": "npm run build --workspace=web",
    "web:lint": "npm run lint --workspace=web",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "dev": "concurrently \"npm run web:dev\" \"npm run convex:dev\"",
    "build": "npm run web:build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
